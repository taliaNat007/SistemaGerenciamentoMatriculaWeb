
<% aluno = locals.aluno || {} %>
<div class="row page-titles mx-0">
    <div class="col-sm-6 p-md-0">
        <div class="welcome-text">
            <h4>
                <%= locals.titulo %>
            </h4>
            <p class="mb-0">&raquo; <%= locals.subtitulo %></p>
        </div>
    </div>
    <div class="col-sm-6 p-md-0 justify-content-sm-end mt-2 mt-sm-0 d-flex">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Inicial</a></li>
            <li class="breadcrumb-item"><a href="/alunos">Consulta de Alunos</a></li>
            <li class="breadcrumb-item active"><a href="javascript:void(0)">Excluir Aluno</a></li>
        </ol>
    </div>
</div>
<!-- row -->
<div class="row">
    <div class="col-lg-8 offset-lg-2">
        <div class="card border-danger">
            <div class="card-header bg-danger p-3">
                <h4 class="card-title text-white mb-0">Exclusão de aluno</h4>
            </div>

            <div class="card-body">
                <div class="alert alert-warning">
                    <b>Está ação excluirá o registro de forma permanente.</b>
                </div>

                <p class="mb-4">
                    Tem certeza que deseja excluir o aluno abaixo?
                </p>

                <div class="table-responsive mb-4">
                    <table class="table table-bordered mb-0">
                        <tbody>
                            <tr>
                                <th>Nome</th>
                                <td><%= aluno.nome %></td>
                            </tr>
                            <tr>
                                <th>Nivel Atual</th>
                                <td><%= aluno.nivelAtual %></td>
                            </tr>
                            
                        </tbody>
                    </table>
                </div>

                <form action="/alunos/<%= aluno.id %>/excluir" method="post">
                    <button type="submit" class="btn btn-danger mr-2">Confirmar Exclusão</button>
                    <a href="/alunos" class="btn btn-secondary">Cancelar</a>
                </form>
            </div>


        </div>
    </div>

</div>