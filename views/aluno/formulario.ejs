<% const erros = validationErrors(locals.errors); %>
<% const aluno = locals.aluno || {} %>

<div class="row page-titles mx-0">
    <div class="col-sm-6 p-md-0">
        <div class="welcome-text">
            <h4>
                <%= locals.titulo %>
            </h4>
            <p class="mb-0">&raquo; Adicionar novo Aluno</p>
        </div>
    </div>
    <div class="col-sm-6 p-md-0 justify-content-sm-end mt-2 mt-sm-0 d-flex">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Inicial</a></li>
            <li class="breadcrumb-item"><a href="/alunos">Consulta de Alunos</a></li>
            <li class="breadcrumb-item active"><a href="javascript:void(0)">Novo Aluno</a></li>
        </ol>
    </div>
</div>
<!-- row -->
<div class="row">
    <div class="col-lg-12">

        <% if (erros.all.length) { %>
            <div class="alert alert-danger">
              <h5>Não foi possível salvar</h5>
              <ul>
                <% erros.all.forEach((mensagem) => { %>
                  <li><%= mensagem %></li>
                <% }) %>
              </ul>
            </div>
          <% } %>

        <div class="card">
            <div class="card-body">
                <form action="/alunos/<%= aluno.id ? aluno.id + '/editar' : 'criar' %>" method="POST">
                    <div class="form-group mb-3">
                        <label for="nome" class="form-label">Nome do Aluno</label>
                        <input type="text" class="form-control <%= erros.has('nome') ? 'is-invalid' : '' %>" 
                            id="nome" name="nome" placeholder="Informe o nome do aluno" value="<%= aluno ? aluno.nome : '' %>">

                            <% if (erros.has('nome')) { %>
                                <div class="invalid-feedback d-block">
                                    <ul>
                                        <% erros.get('nome').forEach((mensagem) => { %>
                                            <li> <%= mensagem %> </li>
                                        <% }) %>
                                    </ul>   
                                </div>
                            <% } %>
                    </div>

                    <div class="form-group mb-3">
                        <label for="cpf" class="form-label">CPF</label>
                        <input type="text" class="form-control <%= erros.has('cpf') ? 'is-invalid' : '' %>" 
                        id="cpf" name="cpf" placeholder="Informe o CPF do aluno" value="<%= aluno ? aluno.cpf : '' %>">

                    </div>

                        <div class="form-group col-md-6 mb-3">
                            <label for="nivelAtual">Nível Atual</label>

                            <select
                                class="form-control"
                                name="nivelAtual"
                                                            >
                                <option value="">Selecione</option>
                            
                                <option value="Iniciante"
                                    <%= aluno.nivelAtual === 'Iniciante' ? 'selected' : '' %>>
                                    Iniciante
                                </option>
                            
                                <option value="Intermediario"
                                    <%= aluno.nivelAtual === 'Intermediario' ? 'selected' : '' %>>
                                    Intermediário
                                </option>
                            
                                <option value="Avancado"
                                    <%= aluno.nivelAtual === 'Avancado' ? 'selected' : '' %>>
                                    Avançado
                                </option>
                            
                                <option value="Oficializado"
                                    <%= aluno.nivelAtual === 'Oficializado' ? 'selected' : '' %>>
                                    Oficializado
                                </option>
                            </select>
                        </div>

                        <div class="form-group col-md-6 mb-3">
                            <label for="dataNascimento" class="form-label">
                                Data de Nascimento
                            </label>

                            <input
                                type="date"
                                class="form-control"
                                id="dataNascimento"
                                name="dataNascimento"
                                value="<%= aluno?.dataNascimento ? String(aluno.dataNascimento).split('T')[0] : '' %>"  
                            >

                            <small class="text-muted">
                                Formato: aaaa-mm-dd
                            </small>
                        </div>
                    </div>

                    <a href="/avaliacoes/criar" class="btn btn-primary mb-2">Adicionar  Avaliacao</a>

                   

                </div>


                    <div class="form-group">
                        <button type="submit" class="btn btn-primary mr-2">Salvar Aluno</button>
                        <a href="/alunos" class="btn btn-warning">Cancelar</a>
                    </div>

                </form>

            </div>
        </div>
    </div>
</div>