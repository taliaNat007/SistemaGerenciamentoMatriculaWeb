<div class="row page-titles mx-0">
    <div class="col-sm-6 p-md-0">
        <div class="welcome-text">
            <h4>
                <%= titulo %>
            </h4>
            <p class="mb-0">&raquo; Consulte todos os alunos do sistema</p>
        </div>
    </div>
    <div class="col-sm-6 p-md-0 justify-content-sm-end mt-2 mt-sm-0 d-flex">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Inicial</a></li>
            <li class="breadcrumb-item active"><a href="javascript:void(0)">Alunos</a></li>
        </ol>
    </div>
</div>
<!-- row -->

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header">
                
                <div class="basic-form flex-grow-1">
                    <form>
                        <div class="form-row">
                            <div class="col-lg-10">
                                <input type="text" class="form-control" placeholder="Digite para pesquisar...">
                            </div>
                            <div class="col-lg-2 mt-2 mt-lg-0">
                                <button type="submit" class="btn btn-warning mb-2">Pesquisar</button>
                            </div>
                        </div>
                    </form>
                </div>

                <a href="/alunos/criar" class="btn btn-primary mb-2">Adicionar Novo Aluno</a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-responsive-sm">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Nome</th>
                                <th>CPF</th>
                                <th>Nivel Atual</th>
                                <th>Data de Nascimento</th>
                                <th>Data de Cadastro</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>

                            <% for( let index = 0; index < alunos.length; index++ ) { %>
                                <tr>
                                    <td><%= index + 1 %></td>
                                    <td><%= alunos[index].nome %></td>
                                    <td><%= alunos[index].cpf %></td>
                                    <td><%= alunos[index].nivelAtual ? 'Iniciante' : 'Intermediário' %></td>                                    <td>
                                    <td>
                                        <% if (alunos[index].nivelAtual) { %>

                                            <span class="badge badge-success">Iniciante</span>

                                        <% } else { %>

                                            <span class="badge badge-warning">Intermediário</span>

                                        <% } %>
                                    </td>
                                    <td><%= new Date(alunos[index].dataNascimento).toLocaleDateString('pt-BR') %></td>
                                    <td><%= dateFormat(alunos[index].dataCadastro) %></td>
                                    <td>
                                        <a href="/alunos/<%= alunos[index].id %>/editar" class="text-warning mr-1">
                                            <i class="fa fa-pencil fa-lg"></i>
                                        </a>
                                        <a href="/alunos/<%= alunos[index].id %>/excluir" class="text-danger">
                                            <i class="fa fa-trash fa-lg"></i>
                                        </a>
                                        
                                        <a href="#" class="text-secondary remover" data-name="<%= alunos[index].nome %>" data-id="<%= alunos[index].id %>">
                                            <i class="fa fa-trash fa-lg"></i>
                                        </a>
                                    </td>
                                </tr>
                            <% } %>

                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>