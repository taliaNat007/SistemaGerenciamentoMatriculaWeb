<div class="row page-titles mx-0">
    <div class="col-sm-6">
        <div class="welcome-text">
            <h4><%= titulo %></h4>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-xl-12">
        <div class="card">
            <div class="card-body">

                <form method="POST">

                    <!-- ALUNO -->
                    <div class="form-group mb-3">
                        <label for="alunoId">Aluno</label>

                        <select
                            name="alunoId"
                            id="alunoId"
                            class="form-control"
                            required
                        >
                            <option value="">
                                Selecione o Aluno
                            </option>

                            <% alunos.forEach(aluno => { %>

                                <option
                                    value="<%= aluno.id %>"
                                    <%= typeof avaliacao !== 'undefined'
                                        && avaliacao.aluno
                                        && avaliacao.aluno.id === aluno.id
                                        ? 'selected'
                                        : '' %>
                                >
                                    <%= aluno.nome %>
                                </option>

                            <% }) %>

                        </select>
                    </div>

                    <!-- NOME DA MÚSICA -->
                    <div class="form-group mb-3">
                        <label for="nomeMusica">Nome da Música</label>

                        <input
                            type="text"
                            id="nomeMusica"
                            name="nomeMusica"
                            class="form-control"
                            value="<%= typeof avaliacao !== 'undefined' ? avaliacao.nomeMusica : '' %>"
                            required
                        >
                    </div>

                    <!-- NOTA -->
                    <div class="form-group mb-3">
                        <label for="nota">Nota</label>

                        <input
                            type="number"
                            id="nota"
                            name="nota"
                            class="form-control"
                            min="0"
                            max="10"
                            step="0.1"
                            value="<%= typeof avaliacao !== 'undefined' ? avaliacao.nota : '' %>"
                            required
                        >
                    </div>

                    <!-- NÍVEL ATINGIDO -->
                    <div class="form-group mb-3">
                        <label for="nivelAtingido">
                            Nível Atingido
                        </label>

                        <select
                            name="nivelAtingido"
                            id="nivelAtingido"
                            class="form-control"
                            required
                        >
                            <option value="">
                                Selecione
                            </option>

                            <option
                                value="1"
                                <%= typeof avaliacao !== 'undefined'
                                    && avaliacao.nivelAtingido
                                    ? 'selected'
                                    : '' %>
                            >
                                Sim
                            </option>

                            <option
                                value="0"
                                <%= typeof avaliacao !== 'undefined'
                                    && !avaliacao.nivelAtingido
                                    ? 'selected'
                                    : '' %>
                            >
                                Não
                            </option>

                        </select>
                    </div>

                    <button
                        type="submit"
                        class="btn btn-primary"
                    >
                        Salvar
                    </button>

                    <a
                        href="/avaliacoes"
                        class="btn btn-secondary"
                    >
                        Cancelar
                    </a>

                </form>

            </div>
        </div>
    </div>
</div>