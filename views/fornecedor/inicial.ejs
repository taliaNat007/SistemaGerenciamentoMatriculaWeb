<div class="row page-titles mx-0">
    <div class="col-sm-6 p-md-0">
        <div class="welcome-text">
            <h4>
                <%= titulo %>
            </h4>
            <p class="mb-0">&raquo; Consulte todos os fornecedores</p>
        </div>
    </div>
    <div class="col-sm-6 p-md-0 justify-content-sm-end mt-2 mt-sm-0 d-flex">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Inicial</a></li>
            <li class="breadcrumb-item active"><a href="javascript:void(0)">Fornecedores</a></li>
        </ol>
    </div>
</div>
<!-- row -->

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header">
                
                <div class="basic-form flex-grow-1">
                    <form>
                        <div class="form-row">
                            <div class="col-lg-10">
                                <input type="text" class="form-control" placeholder="Digite para pesquisar...">
                            </div>
                            <div class="col-lg-2 mt-2 mt-lg-0">
                                <button type="submit" class="btn btn-warning mb-2">Pesquisar</button>
                            </div>
                        </div>
                    </form>
                </div>

                <a href="/fornecedores/criar" class="btn btn-primary mb-2">Adicionar Novo Fornecedor</a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-responsive-sm">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Nome</th>
                                <th>Ativo</th>
                                <th>Criado em</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>

                            <% for( let index = 0; index < fornecedores.length; index++ ) { %>
                                <tr>
                                    <td><%= index + 1 %></td>
                                    <td><%= fornecedores[index].nome %></td>
                                    <td>
                                        <% if (fornecedores[index].ativo) { %>

                                            <span class="badge badge-primary">Ativo</span>

                                        <% } else { %>

                                            <span class="badge badge-danger">Inativo</span>

                                        <% } %>
                                    </td>
                                    <td><%= dateFormat(fornecedores[index].criadoEm) %></td>
                                    <td>
                                        <a href="/fornecedores/<%= fornecedores[index].id %>/editar" class="text-warning mr-1">
                                            <i class="fa fa-pencil fa-lg"></i>
                                        </a>
                                        <a href="/fornecedores/<%= fornecedores[index].id %>/excluir" class="text-danger">
                                            <i class="fa fa-trash fa-lg"></i>
                                        </a>
                                        
                                        <a href="#" class="text-secondary remover" data-name="<%= fornecedores[index].nome %>" data-id="<%= fornecedores[index].id %>">
                                            <i class="fa fa-trash fa-lg"></i>
                                        </a>
                                    </td>
                                </tr>
                            <% } %>

                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>